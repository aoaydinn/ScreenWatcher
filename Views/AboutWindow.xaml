<Window x:Class="ScreenWatcher.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hakkında" Height="200" Width="300"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="ScreenWatcher" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock x:Name="VersionText" Text="Versiyon: 1.0.0" FontSize="14" Margin="0,10,0,5" HorizontalAlignment="Center"/>
        <TextBlock Text="Geliştirici: aoaydin" FontSize="14" HorizontalAlignment="Center"/>
        <Button Content="Tamam" Width="80" Margin="0,20,0,0" Click="Close_Click"/>
    </StackPanel>
</Window>
