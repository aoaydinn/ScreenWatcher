<Application x:Class="ScreenWatcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             Startup="Application_Startup"
             Exit="Application_Exit">
    <Application.Resources>
        <!-- The taskbar context menu -->
        <ContextMenu x:Key="TrayMenu">
            <MenuItem Header="Ayarlar" Click="MenuSettings_Click" />
            <MenuItem Header="Hakkında" Click="MenuAbout_Click" />
            <Separator />
            <MenuItem Header="Çıkış" Click="MenuExit_Click" />
        </ContextMenu>

        <!-- The taskbar icon -->
        <tb:TaskbarIcon x:Key="MyNotifyIcon"
                        ToolTipText="ScreenWatcher Arka Planda Çalışıyor"
                        ContextMenu="{StaticResource TrayMenu}"
                        MenuActivation="RightClick"
                        TrayMouseDoubleClick="MenuSettings_Click"/>
    </Application.Resources>
</Application>
